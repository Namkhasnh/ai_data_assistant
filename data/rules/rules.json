    {
      "id": "rule_regex_experience_001",
      "type": "regex",
      "column": "experience",
      "parameters": {
        "pattern": "(\\d+)",
        "output_columns": [
          "experience_years"
        ],
        "output_types": {
          "experience_years": "int"
        }
      },
      "enabled": true,
      "priority": 30,
      "description": "Extract numeric years from experience.",
      "created_by": "semantic"
    },
    {
      "id": "rule_regex_salary_001",
      "type": "regex",
      "column": "salary",
      "parameters": {
        "pattern": "(\\d+)\\s*-\\s*(\\d+)",
        "output_columns": [
          "salary_min",
          "salary_max"
        ],
        "output_types": {
          "salary_min": "int",
          "salary_max": "int"
        }
      },
      "enabled": true,
      "priority": 30,
      "description": "Extract numeric range from salary.",
      "created_by": "semantic"
    },
    {
      "id": "rule_validation_experience_years_001",
      "type": "validation",
      "column": "experience_years",
      "parameters": {
        "operator": ">=",
        "value": 0,
        "message": "experience_years must be >= 0",
        "allow_null": true
      },
      "enabled": true,
      "priority": 40,
      "description": "Validate derived numeric column experience_years.",
      "created_by": "semantic"
    },
    {
